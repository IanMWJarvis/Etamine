---
// import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
// import '../styles/global.css';

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- <link rel="stylesheet" href="src/styles/global.css"> -->
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} >
    <title>Astro</title>
    <!-- Put this anywhere in your HTML -->
<audio id="global-player" preload="auto"></audio>
  </head>
  <body>
    <Layout>
      <main class="universe-container">
        <div class="stars-base"></div>
        <div class="foreground-image">
          <img src="../images/etamine_logo.png" alt="Etamine-logo" class="logo"></div>
        </div>
        <div class="video-backgrounds">
          <video id="video-rotating-bodies" class="track-video" src="/video/rotating-bodies-video.mp4" muted loop playsinline></video>
          <video id="video-3-cycle-multi-programme" class="track-video" src="/video/3-cycle-video.mp4" muted loop playsinline></video>
          <video id="video-london-extended-stay" class="track-video" src="/video/london-extended-video.mp4" muted loop playsinline></video>
          <video id="video-helicopter-takeoff-at-night" class="track-video" src="/video/helicopter-video.mp4" muted loop playsinline></video>
          <video id="video-the-arrow-of-time" class="track-video" src="/video/arrow-video.mp4" muted loop playsinline></video>
          <video id="video-antiblue" class="track-video" src="/video/antiblue-video.mp4" muted loop playsinline></video>
          <video id="video-plastic-peaches" class="track-video" src="/video/plastic-peaches-video.mp4" muted loop playsinline></video>
          <video id="video-unnatural-causes" class="track-video" src="/video/unnatural-video.mp4" muted loop playsinline></video>
          <video id="video-zoe" class="track-video" src="/video/zoe-video.mp4" muted loop playsinline></video>
          <video id="video-virtual-traverse" class="track-video" src="/video/virtual-video.mp4" muted loop playsinline></video>
        </div>
        <nav class="star-map">
          <div class="track-item" style="top: 20%; left: 15%;" data-track="rotating-bodies" data-audio="/audio/rotating-bodies.mp3">
            <div class="label">
              <span class="track-name">Rotating Bodies</span>
              <div class="arrow" style="transform: rotate(0deg);"></div>
            </div>
          </div>
          <div class="track-item" style="top: 30%; left: 20%;" data-track="3-cycle-multi-programme" data-audio="/audio/3-cycle-multi-programme.mp3">
            <div class="label">
              <span class="track-name">3 Cycle Multi-Programme</span>
              <div class="arrow" style="transform: rotate(90deg);"></div>
            </div>
          </div>
          <div class="track-item" style="top: 50%; left: 10%;" data-track="london-extended-stay" data-audio="/audio/london-extended-stay.mp3">
            <div class="label">
              <span class="track-name">London Extended Stay</span>
              <div class="arrow" style="transform: rotate(225deg);"></div>
            </div>
          </div>
          <div class="track-item" style="top: 55%; left: 30%;" data-track="helicopter-takeoff-at-night" data-audio="/audio/helicopter-takeoff-at-night.mp3">
            <div class="label">
              <span class="track-name">Helicopter Takeoff at Night</span>
              <div class="arrow" style="transform: rotate(225deg);"></div>
            </div>
          </div>
          <div class="track-item" style="top: 64%; left: 15%;" data-track="the-arrow-of-time" data-audio="/audio/the-arrow-of-time.mp3">
            <div class="label">
              <span class="track-name">The Arrow of Time</span>
              <div class="arrow" style="transform: rotate(225deg);"></div>
            </div>
          </div>
          <div class="track-item" style="top: 24%; left: 80%;" data-track="antiblue" data-audio="/audio/antiblue.mp3">
            <div class="label">
              <span class="track-name">AntiBlue</span>
              <div class="arrow" style="transform: rotate(225deg);"></div>
            </div>
          </div>
          <div class="track-item" style="top: 34%; left: 55%;" data-track="plastic-peaches" data-audio="/audio/plastic-peaches.mp3">
            <div class="label">
              <span class="track-name">Plastic Peaches</span>
              <div class="arrow" style="transform: rotate(225deg);"></div>
            </div>
          </div>
          <div class="track-item" style="top: 47%; left: 88%;" data-track="unnatural-causes" data-audio="/audio/unnatural-causes.mp3">
            <div class="label">
              <span class="track-name">Unnatural Causes</span>
              <div class="arrow" style="transform: rotate(225deg);"></div>
            </div>
          </div>
          <div class="track-item" style="top: 55%; left: 65%;" data-track="zoe" data-audio="/audio/zoe.mp3">
            <div class="label">
              <span class="track-name">Zoe</span>
              <div class="arrow" style="transform: rotate(225deg);"></div>
            </div>
          </div>
          <div class="track-item" style="top: 80%; left: 86%;" data-track="virtual-traverse" data-audio="/audio/virtual-traverse.mp3">
            <div class="label">
              <span class="track-name">Virtual Traverse</span>
              <div class="arrow" style="transform: rotate(225deg);"></div>
            </div>
          </div>
        </nav>
      </main>

    </Layout>
  </body>
</html>

<script>
  // 1. Find all the stars/tracks
  const trackItems = document.querySelectorAll('.track-item');
  // 2. Find the hidden audio element
  const player = document.getElementById('global-player');

  trackItems.forEach(item => {
    item.addEventListener('mouseenter', () => {
      // 3. THIS IS THE LINK: Get the path from the data-audio attribute
      const trackId = item.getAttribute('data-track');
      const audioPath = item.getAttribute('data-audio');

      // 4. Tell the player which file to use and play it
      player.src = audioPath;
      player.play().catch(e => console.log("Audio blocked until user interacts with page."));
      item.classList.add("track-item-hover");

      const targetVideo = document.getElementById(`video-${trackId}`);
      if (targetVideo) {
        targetVideo.classList.add('active');
        targetVideo.play();
      }
    });

    item.addEventListener('mouseleave', () => {
      // 5. Stop the music when the mouse leaves
      const trackId = item.getAttribute('data-track');
      player.pause();
      player.currentTime = 0;
      item.classList.remove("track-item-hover"); // Reset to start

      const targetVideo = document.getElementById(`video-${trackId}`);
      if (targetVideo) {
        targetVideo.classList.remove('active');
        targetVideo.pause();
        targetVideo.currentTime = 0; // Optional: Reset video to start
      }
    });
  });
</script>
